<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.OpenCourt" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="colorControlHighlight">@color/colorPrimaryRipple</item>
        <item name="colorControlNormal">@android:color/white</item>
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">@android:color/white</item>
    </style>

    <style name="Theme.OpenCourt" parent="Base.Theme.OpenCourt" />

    <style name="CustomDatePickerTheme" parent="Theme.Material3.DayNight.Dialog">
        <!-- Background boja -->
        <item name="android:background">#233C4C</item>
        <item name="colorSurface">#233C4C</item>

        <!-- Header boja (plava kao tvoj dizajn) -->
        <item name="colorPrimary">#2196F3</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- Selektovani datum -->
        <item name="colorAccent">#2196F3</item>

        <!-- Tekst boje -->
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">#B3FFFFFF</item>

        <!-- Dugmići (Cancel/OK) -->
        <item name="colorOnSurface">@android:color/white</item>
        <item name="android:buttonBarButtonStyle">@style/DatePickerButton</item>
    </style>

    <style name="DatePickerButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">#2196F3</item>
    </style>



</resources>