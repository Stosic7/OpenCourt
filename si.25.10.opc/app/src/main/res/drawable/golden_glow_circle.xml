<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow (blur effect) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#60FFD700" />
            <size android:width="20dp" android:height="20dp" />
        </shape>
    </item>

    <!-- Middle glow layer -->
    <item
        android:top="2dp"
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp">
        <shape android:shape="oval">
            <solid android:color="#A0FFD700" />
        </shape>
    </item>

    <!-- Inner circle (bright gold) -->
    <item
        android:top="4dp"
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp">
        <shape android:shape="oval">
            <solid android:color="#FFD700" />
        </shape>
    </item>
</layer-list>
