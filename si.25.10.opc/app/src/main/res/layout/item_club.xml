<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="28dp"
    app:cardUseCompatPadding="false"
    app:cardBackgroundColor="#1AFFFFFF"
    app:strokeColor="#33FFFFFF"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/imgClub"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/tenis_court"
            android:alpha="0.92"
            android:padding="15dp"
            android:translationY="-10dp"
            tools:src="@drawable/tenis_court" />

        <View
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bottom_fade" />

        <LinearLayout
            android:id="@+id/textPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="1dp">

            <TextView
                android:id="@+id/tvClubName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="22sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:shadowColor="#B3000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                tools:text="Naziv Kluba" />

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:layout_marginTop="2dp"
                tools:text="Udaljenost – 500km" />
        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
