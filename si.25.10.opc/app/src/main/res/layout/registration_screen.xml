<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FF233C4C">

    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".RegistrationScreen">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="120dp"
            android:scaleType="fitCenter"
            android:scaleX="1.2"
            android:src="@drawable/triangle"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registracija"
            android:textColor="@android:color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginTop="48dp"
            android:layout_centerHorizontal="true" />

        <LinearLayout
            android:id="@+id/formLayout"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/title"
            android:layout_marginTop="40dp"
            android:layout_marginHorizontal="32dp">

            <EditText
                android:id="@+id/etIme"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/rounded_corners"
                android:hint="Ime"
                android:padding="16dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF" />

            <EditText
                android:id="@+id/etPrezime"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/rounded_corners"
                android:hint="Prezime"
                android:padding="16dp"
                android:layout_marginTop="12dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF" />

            <EditText
                android:id="@+id/etTelefon"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/rounded_corners"
                android:hint="Broj telefona"
                android:inputType="phone"
                android:padding="16dp"
                android:layout_marginTop="12dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/rounded_corners"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:padding="16dp"
                android:layout_marginTop="12dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF" />

            <EditText
                android:id="@+id/etSifra"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/rounded_corners"
                android:hint="Šifra"
                android:inputType="textPassword"
                android:padding="16dp"
                android:layout_marginTop="12dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF" />

            <EditText
                android:id="@+id/etPonoviSifru"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/rounded_corners"
                android:hint="Ponovi šifru"
                android:inputType="textPassword"
                android:padding="16dp"
                android:layout_marginTop="12dp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF" />

            <!-- Checkbox for Club Admin -->
            <CheckBox
                android:id="@+id/cbClubAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Administrator teniskog kluba"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:buttonTint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="* Samo ukoliko posedujete teniski klub"
                android:textColor="#B3FFFFFF"
                android:textSize="11sp"
                android:textStyle="italic"
                android:paddingStart="32dp" />

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRegistrujSe"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_below="@id/formLayout"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="50dp"
            android:layout_centerHorizontal="true"
            android:text="Registruj se"
            android:elevation="6dp"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:background="@drawable/blue_button" />

    </RelativeLayout>
</ScrollView>
