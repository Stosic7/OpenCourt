<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/onboardingScreen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF233C4C"
    tools:context=".FirstTimeNotificationActivity">


    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:layout_marginTop="120dp"
        android:scaleX="1.2"
        android:src="@drawable/triangle"
        />

    <!-- Naslov -->
    <TextView
        android:id="@+id/oNamaTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dobrodošli u OpenCourt!"
        android:textColor="@android:color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="40dp"
        android:layout_centerHorizontal="true" />

    <!-- Prva kartica -->
    <LinearLayout
        android:id="@+id/card1"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_below="@id/oNamaTitle"
        android:layout_marginTop="32dp"
        android:layout_centerHorizontal="true"
        android:orientation="vertical"
        android:background="@drawable/rounded_card"
        android:padding="20dp">

        <TextView
            android:id="@+id/naslov1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Brza i jednostavna rezervacija"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:id="@+id/text1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zaboravite na pozive, poruke i Viber grupe – uz OpenCourt, slobodan teniski teren pronaći ćete u samo nekoliko sekundi.\nNaša aplikacija vam omogućava da pregledate dostupne terene u realnom vremenu, filtrirate po lokaciji, ceni i podlozi, i odmah rezervišete željeni termin – bez greške, duplih zakazivanja ili stresa."
            android:textColor="#B0E4E4"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="6dp"
            android:textAlignment="center" />
    </LinearLayout>

    <!-- Druga kartica -->
    <LinearLayout
        android:id="@+id/card2"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_below="@id/card1"
        android:layout_marginTop="20dp"
        android:layout_centerHorizontal="true"
        android:orientation="vertical"
        android:background="@drawable/rounded_card"
        android:padding="20dp">

        <TextView
            android:id="@+id/naslov2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:text="Više od rezervacije" />

        <TextView
            android:id="@+id/text2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="6dp"
            android:text="🔎 Pregledajte komentare i ocene drugih igrača.\n🤝 Pronađite sparing partnere i organizujte mečeve.\n📍 Pratite mape i lako se snađite do terena.\n🏅 Gradite svoj profil, beležite rezultate i napredujte.\n\nPridružite se, igrajte više i uživajte u svakom setu."
            android:textAlignment="viewStart"
            android:textColor="#B0E4E4"
            android:textSize="14sp" />

        <View
            android:id="@+id/diagonalFill"
            android:layout_width="2400dp"
            android:layout_height="10dp"
            android:background="@drawable/diagonal_fill"
            android:rotation="29"
            android:translationX="145dp"
            android:translationY="160dp" />
    </LinearLayout>

    <!-- Dugme Nastavi -->



    <!-- drawable/rectangle_1.xml -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/continueButton"
        android:layout_width="140dp"
        android:layout_height="40dp"
        android:elevation="60dp"
        android:layout_below="@id/card2"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="11dp"
        android:text="Nastavi"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:background="@drawable/background_for_button"
        android:backgroundTint="@null" />


</RelativeLayout>
