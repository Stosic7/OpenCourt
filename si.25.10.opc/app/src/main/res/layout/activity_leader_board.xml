<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#233C4C"
    tools:context=".LeaderBoardActivity">

    <!-- Background Triangle -->

    <!-- HEADER -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="120dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:scaleX="1.2"
        android:src="@drawable/triangle" />

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:contentDescription="@string/back"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@android:color/white"
            app:icon="@drawable/arrow_left"
            app:iconTint="@android:color/white"
            app:iconGravity="textStart"
            app:iconSize="24dp" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ranglista"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Top 3 Podium Section -->
    <LinearLayout
        android:id="@+id/podiumSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:baselineAligned="false">

        <!-- 2nd Place -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="4dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/baseline_person_24"
                android:contentDescription="Avatar"
                app:tint="@android:color/white"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvSecondName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="4dp"
                tools:text="Marko M." />

            <TextView
                android:id="@+id/tvSecondScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#C0C0C0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                tools:text="850 🏆" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="80dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#C0C0C0">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="2"
                    android:textColor="#233C4C"
                    android:textStyle="bold"
                    android:textSize="32sp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- 1st Place -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/baseline_person_24"
                android:contentDescription="Avatar"
                app:tint="#FFD700"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvFirstName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="4dp"
                tools:text="Luka S." />

            <TextView
                android:id="@+id/tvFirstScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFD700"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                tools:text="1200 🏆" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="110dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFD700">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="1"
                    android:textColor="#233C4C"
                    android:textStyle="bold"
                    android:textSize="40sp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- 3rd Place -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="4dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/baseline_person_24"
                android:contentDescription="Avatar"
                app:tint="@android:color/white"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvThirdName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="4dp"
                tools:text="Ana P." />

            <TextView
                android:id="@+id/tvThirdScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CD7F32"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                tools:text="720 🏆" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#CD7F32">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="3"
                    android:textColor="#233C4C"
                    android:textStyle="bold"
                    android:textSize="28sp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </LinearLayout>

    <!-- Rest of Leaderboard -->
    <TextView
        android:id="@+id/tvRestLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/podiumSection"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="12dp"
        android:text="Ostali igrači"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="18sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLeaderboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tvRestLabel"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp"
        tools:listitem="@layout/item_leaderboard_complete" />

    <!-- LOADING OVERLAY -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:elevation="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@drawable/progress_panel_bg"
            android:elevation="22dp">

            <ProgressBar
                android:id="@+id/progress"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:indeterminateTint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Učitavanje..."
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </FrameLayout>

</RelativeLayout>
