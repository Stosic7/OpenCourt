<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/booking_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#233C4C"
    tools:context=".BookingActivity">

    <!-- Background Triangle -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="120dp"
        android:scaleType="fitCenter"
        android:scaleX="1.2"
        android:src="@drawable/triangle"
        android:contentDescription="@null" />

    <!-- Header Row -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:contentDescription="@string/abc_action_bar_up_description"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@android:color/white"
            app:icon="@drawable/arrow_left"
            app:iconTint="@android:color/white"
            app:iconGravity="textStart"
            app:iconSize="24dp" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rezervacija"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/bottomSection"
        android:layout_marginTop="16dp"
        android:fillViewport="true"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Klub • Teren -->
            <TextView
                android:id="@+id/tvClubCourt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Klub • Teren"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="20dp" />

            <!-- Datum Section -->
            <TextView
                android:id="@+id/tvDateLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Datum"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPickDate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/rounded_corners"
                android:text="Izaberi datum"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="20dp" />

            <!-- Trajanje Section -->
            <TextView
                android:id="@+id/tvDurationLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trajanje"
                android:textColor="@android:color/white"
                android:textColorHighlight="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColorHighlightInverse="@android:color/white"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerDuration"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/rounded_corners"
                android:spinnerMode="dropdown"
                android:textColor="@android:color/white"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="20dp" />

            <!-- Broj igrača Section -->
            <TextView
                android:id="@+id/tvPlayersLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Broj igrača"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/rounded_corners"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="20dp">

                <NumberPicker
                    android:id="@+id/npPlayers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:descendantFocusability="blocksDescendants" />
            </LinearLayout>

            <!-- Slobodni termini -->
            <TextView
                android:id="@+id/tvSlotsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Slobodni termini"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTimeSlots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="200dp"
                android:clipToPadding="false"
                tools:listitem="@layout/item_time_slot" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Section -->
    <LinearLayout
        android:id="@+id/bottomSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:background="@drawable/rounded_dark_bar"
        android:elevation="8dp">

        <!-- Cena -->
        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cena: —"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRentEquipment"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:background="@drawable/rounded_corners"
                android:text="Iznajmi opremu"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:enabled="false"
                android:alpha="0.5"
                android:layout_marginEnd="8dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReserve"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:background="@drawable/blue_button"
                android:text="Rezerviši"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:elevation="6dp"
                android:enabled="false"
                android:alpha="0.5"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
