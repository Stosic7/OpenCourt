<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="12dp">

    <!-- Received Message (from other person) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/receivedMessageCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginEnd="80dp"
        android:layout_marginStart="8dp"
        app:cardCornerRadius="18dp"
        app:cardBackgroundColor="#E8F5E9"
        app:cardElevation="2dp"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/tvReceivedMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1B5E20"
                android:textSize="16sp"
                android:lineSpacingExtra="2dp"
                android:maxWidth="260dp"
                android:paddingEnd="8dp"
                tools:text="Zdravo! Da li je još uvek dostupno?" />

            <TextView
                android:id="@+id/tvReceivedTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#66BB6A"
                android:textSize="12sp"
                android:layout_gravity="end"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"
                tools:text="14:06" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Sent Message (your message) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/sentMessageCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginStart="80dp"
        android:layout_marginEnd="8dp"
        app:cardCornerRadius="18dp"
        app:cardBackgroundColor="#2196F3"
        app:cardElevation="2dp"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/tvSentMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:lineSpacingExtra="2dp"
                android:maxWidth="260dp"
                android:paddingEnd="8dp"
                tools:text="Da, još uvek je dostupno!" />

            <!-- Time + Seen Status Row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="end"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvSentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#E3F2FD"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="4dp"
                    tools:text="19:57" />

                <!-- Seen Status (double check marks) -->
                <TextView
                    android:id="@+id/tvSeenStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textColor="#90CAF9"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="visible"
                    tools:text="✓✓" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
